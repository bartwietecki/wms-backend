# WMS Backend - environment variable template

# LOCAL DEV:

#   cp .env.example .env
#   Fill in values, then: docker compose up -d

# PRODUCTION:

#   Populate these on your server / CI secrets store.
#   Run: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d

# PostgreSQL

POSTGRES_DB=wms
POSTGRES_USER=wms
POSTGRES_PASSWORD=           # REQUIRED - use a strong random password in production

# Keycloak admin console

KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=  # REQUIRED - use a strong password (only used for initial bootstrap)
KC_HOSTNAME_URL=              # REQUIRED in prod - public Keycloak URL, e.g. https://auth.example.com
                              # Local dev default: http://localhost:9090

# WMS application users (Basic Auth fallback + Keycloak realm seed)

WMS_ADMIN_USERNAME=admin
WMS_ADMIN_PASSWORD=           # REQUIRED - admin Basic Auth password
WMS_EMPLOYEE_PASSWORD=        # REQUIRED - shared password seeded into Keycloak for demo employees

# CORS

# Comma-separated list of allowed frontend origins.
# Local dev default (applied when var is unset): http://localhost:5173
WMS_CORS_ALLOWED_ORIGINS=     # Production example: https://app.example.com

# JWT (Keycloak)

# issuer-uri: must match the `iss` claim Keycloak embeds in tokens (public-facing URL).
# Local dev default: http://localhost:9090/realms/wms
WMS_JWT_ISSUER_URI=           # Production example: https://auth.example.com/realms/wms

# jwk-set-uri: where the backend fetches public signing keys.
# Use the Docker-internal hostname when running in the same Compose network.
# Local dev default: http://keycloak:8080/realms/wms/protocol/openid-connect/certs
WMS_JWT_JWK_SET_URI=          # Production (same Compose): http://keycloak:8080/realms/wms/protocol/openid-connect/certs

# Frontend build (baked into the static bundle at build time)

# Public-facing Keycloak URL, reachable from the BROWSER (not the Docker-internal hostname).
# Local dev default (applied when var is unset): http://localhost:9090
# REQUIRED in production - frontend image build fails loudly if missing.
VITE_KEYCLOAK_URL=            # Production example: https://auth.example.com
